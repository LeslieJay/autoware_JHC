<?xml version="1.0"?>
<launch>
  <include file="$(find-pkg-share tier4_sensing_launch)/launch/sensing.launch.xml">
    <arg name="launch_driver" value="$(var launch_sensing_driver)"/>
    <arg name="sensor_model" value="$(var sensor_model)"/>
    <arg name="vehicle_param_file" value="$(find-pkg-share $(var vehicle_model)_description)/config/vehicle_info.param.yaml"/>
    <arg name="vehicle_mirror_param_file" value="$(find-pkg-share $(var vehicle_model)_description)/config/mirror.param.yaml"/>
    <arg name="pointcloud_container_name" value="$(var pointcloud_container_name)"/>
  </include>

  <include file="$(find-pkg-share lidar_transform)/launch/points_raw_transform.launch.xml">
    <arg name="RadiusOutlierFilter"  value="1.5"/>
    <arg name="transform_x" value="0.99565"/>
    <arg name="transform_y"  value="0.0"/>
    <arg name="transform_z"  value="2.08054"/>
    <arg name="transform_roll"  value="0.0"/>
    <arg name="transform_pitch"  value="0.0"/>
    <arg name="transform_yaw" value="0.0"/>
  </include>

  <!-- <include file="$(find-pkg-share lidar_transform)/launch/concatenated_pointclouds.xml">
    <arg name="input/twist" default="/sensing/vehicle_velocity_converter/twist_with_covariance"/>
    <arg name="output" default="/sensing/lidar/concatenated/pointcloud"/>
    <arg name="param_file" default="/media/f/nvme_storage/autoware/src/universe/autoware_universe/sensing/autoware_pointcloud_preprocessor/config/concatenate_and_time_sync_node.param.yaml"/>
  </include> -->



</launch>
